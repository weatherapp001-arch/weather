// File Name: firestore.rules
// Element Name: Firestore Security Rules Configuration

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for Admin access
    // Line 9: Function to verify Admin UID
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'eurBOkHyrMMbeti2vzGKPpqFDO13';
    }

    // Collection 'users': Prevent anyone (except Admin) from deleting profiles
    match /users/{userId} {
      // Line 16: Temporarily bypass Auth for development
      allow read, create, update: if true; 
      allow delete: if isAdmin();
    }

    // Collection 'alertSlots': Secure slots for frictionless emergency contacts
    match /alertSlots/{userId} {
      // Line 23: Temporarily bypass Auth for development
      allow read, create, update: if true; 
      
      // Line 26: Strictly block full document deletion to prevent console wiping
      allow delete: if isAdmin();
    }

    // Collection 'fcm_tokens': Allow adding tokens, but block deletion
    match /fcm_tokens/{tokenId} {
      // Line 32: Temporarily bypass Auth to fix Missing Permissions error at usePushNotifications.js:56
      allow create, update: if true; 
      
      // Line 35: Strictly block the delete operation for everyone except Admin
      allow delete: if isAdmin();
      
      allow read: if isAdmin();
    }

    // Collection 'global_alerts': Standard Admin-only write access
    match /global_alerts/{alertId} {
      // Line 41: Temporarily bypass Auth for development reading
      allow read: if true; 
      allow write: if isAdmin();
    }
  }
}